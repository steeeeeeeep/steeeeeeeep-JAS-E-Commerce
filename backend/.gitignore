## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Rider
.idea/
*.sln.iml
*.swp
*.swo
*~

# Visual Studio Code
.vscode/
*.code-workspace

# Visual Studio
.vs/
bin/
obj/
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/

# NuGet
*.nupkg
*.snupkg
.nuget/

# Entity Framework
Migrations/
*.db
*.db-shm
*.db-wal

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db
